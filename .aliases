#!/usr/bin/env bash
#
# Aliases
#
# @author Charlie Revett

# Dates
alias week='date +%V'

# Directories
alias ~='cd $HOME'
alias dotfiles='cd ~/projects/github.com/revett/dotfiles'
alias rev='cd ~/projects/github.com/revett'
alias 8th='cd ~/projects/github.com/8thpark'

# General
alias reload='source ~/.zshrc'

# Git
# gfo → grebase → gpush
# gpull
# gaa → grestore → gd
alias gst='git status'
alias gco='git checkout'
alias gcm='git checkout main'
alias gcb='git checkout -b'
alias gaa='git add --all && git diff --staged && git status'
alias gcom='git commit'
alias gd='git diff'
alias gds='git diff --staged'
alias gfo='git fetch origin'
alias glog='git log --oneline --decorate --graph'
alias grebase='git rebase origin/main'
alias grestore='git restore --staged .'
alias gpull='git pull --rebase'

# Network
alias localip='ifconfig -l | xargs -n1 ipconfig getifaddr'
alias ip='localip'

# Set BSD ls to use coreutils gls
alias ls='gls --color'

# ---
# Personal
# ---

if [[ "$DOTFILES_MACHINE_TYPE" == "PERSONAL" ]]; then
  alias mono='cd ~/projects/github.com/8thpark/mono'
fi

# ---
# Work
# ---

if [[ "$DOTFILES_MACHINE_TYPE" == "WORK" ]]; then
  alias work='cd ~/projects/github.com/team-plain'
  alias pn='pnpm'
  alias plain:infra:run='aws-login dev-charlie-admin && pn install && pn start'
  alias plain:services:nuke='clear && pn clean:dist && pn install && pn run format:fix && pn run lint:fix && pn run gen:monorepo && pn typecheck:services'
  alias plain:services:run='pn install && aws-login dev-charlie-admin && pn run dev'
fi
