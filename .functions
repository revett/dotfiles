#!/usr/bin/env bash
#
# Functions
#
# @author Charlie Revett (@revcd)

# `asd` outputs all available functions from this file.
asd() {
  echo "> Available bash functions"
  echo "> See: ~/projects/github.com/revett/dotfiles/.functions"
  grep '^[a-z].*()' ~/projects/github.com/revett/dotfiles/.functions | grep -v '^asd' | sed 's/() {//' | sed 's/^/  - /'
}

# `branch` is used within a number of aliases, and returns the branch from the current git
# directory. Taken from oh-my-zsh.
# See: https://gist.github.com/DavidToca/3086571
branch() {
  ref=$(git symbolic-ref HEAD 2> /dev/null) || return
  echo ${ref#refs/heads/}
}

# `ccl` starts a lighweight Claude Code session inside Agent Safehouse, using a cheaper model and
# effort level to reduce cost when working from my personal account.
ccl() {
  clear
  safe claude --effort high --model opusplan --dangerously-skip-permissions "$@"
}

# `ccr` starts a read-only Claude Code session inside Agent Safehouse. Edit, Write, and
# NotebookEdit tools are disabled to prevent file modifications.
ccr() {
  clear
  safe claude --effort max --model opus[1m] --dangerously-skip-permissions --disallowedTools "Edit,Write,NotebookEdit" "$@"
}

# `ccw` starts a Claude Code session inside Agent Safehouse with full tool access.
ccw() {
  clear
  safe claude --effort max --model opus[1m] --dangerously-skip-permissions "$@"
}

# `cmuxhelp` is a function to show the available cmux aliases.
cmuxhelp() {
  echo "> Available cmux aliases"
  echo "> See: ~/projects/github.com/revett/dotfiles/.aliases, ~/projects/github.com/revett/dotfiles/.functions"
  alias | grep "='cmux " | sed "s/^/  - /"
}

# `gcai` is a function to generate a git commit message for staged changes using Claude, then prompt
# for confirmation before committing. Single sentence, capitalised first word, no trailing period.
gcai() {
  gst

  local diff
  diff=$(git diff --staged)

  if [[ -z "$diff" ]]; then
    echo "> error: no staged changes" >&2
    return 1
  fi

  local model="haiku"
  echo "> generating commit via claude (model: $model)"
  local msg
  msg=$(echo "$diff" | safe claude -p \
    "Write a git commit message for these staged changes. \
    Single sentence only, no prefix (no feat:, fix:, chore: etc). \
    First word must be capitalised. \
    No trailing period. \
    Output only the commit message, nothing else." \
    --model "$model")

  if [[ -z "$msg" ]]; then
    echo "> error: failed to generate commit message" >&2
    return 1
  fi

  if ! vared -p "> commit: " msg; then
    echo ""
    echo "> aborted"
    return 1
  fi

  if [[ -z "$msg" ]]; then
    echo "> error: commit message is empty" >&2
    return 1
  fi

  if [[ "$msg" == *$'\n'* ]]; then
    echo "> error: commit message must be a single line" >&2
    return 1
  fi

  local max_length=72
  if [[ ${#msg} -gt $max_length ]]; then
    echo "> error: commit message exceeds $max_length characters (${#msg})" >&2
    return 1
  fi

  git commit -m "$msg"
  echo "> done"
  echo ""
  echo ""
  git log -1 --stat HEAD
}

# `githelp` is a function to show the available Git aliases and functions.
githelp() {
  echo "> Available Git aliases"
  echo "> See: ~/projects/github.com/revett/dotfiles/.aliases, ~/projects/github.com/revett/dotfiles/.functions"
  alias | grep "='git " | sed "s/^/  - /"
  echo "  - gcai → Generate commit message via Claude, then commit"
  echo "  - gpush → Force push current branch (blocks main)"
  echo "  - gpush --yolo → Regular push on main (side projects)"
  echo "> Flows:"
  echo "  - gaa → gcai → gpush"
  echo "  - gfo → grebase → gpush"
}

# `gh-repo-slug` returns the GitHub owner/repo slug (e.g. "revett/dotfiles") for the current git
# repository, derived from the origin remote URL. Supports both SSH and HTTPS remotes.
gh-repo-slug() {
  local url
  url=$(git remote get-url origin 2>/dev/null) || {
    echo "error: not a git repository or no origin remote" >&2
    return 1
  }

  local slug
  case "$url" in
    git@github.com:*)
      slug="${url#git@github.com:}"
      ;;
    https://github.com/*)
      slug="${url#https://github.com/}"
      ;;
    *)
      echo "error: origin is not a github.com remote" >&2
      return 1
      ;;
  esac

  slug="${slug%.git}"
  echo "$slug"
}

# `gpush` is a function to push the current branch to the remote repository. It will force push
# the branch if the current branch is not main. It will also allow for a `--yolo` flag to bypass
# the main branch check.
gpush() {
  if [ "$(branch)" = "main" ]; then
    if [ "$1" = "--yolo" ]; then
      git push
      return
    fi
    echo "error: don't force push main (use gpush --yolo)"
    return 1
  fi
  git push --force-with-lease --set-upstream origin "$(branch)"
}


# `render-bw-frame` is a function to add a white border to an image and make it square with a black
# background. The function takes one or more image files as arguments and processes each image
# file. The processed images are saved in the same directory as the original image files with the
# suffix `-bw_frame.jpg`.
render-bw-frame() {
  # Function to add white border and make the image square with a black background
  process_image() {
    local input="$1"
    local filename=$(basename "$input")
    local output="${filename%.*}-bw_frame.jpg"

    # Add white border
    ffmpeg -i "$input" -vf "pad=iw+180:ih+180:90:90:white" -update 1 -frames:v 1 "${filename%.*}-white_border.jpg"

    # Make the image square with a black background
    ffmpeg -i "${filename%.*}-white_border.jpg" -vf "scale=iw*min(3840/iw\,3840/ih):ih*min(3840/iw\,3840/ih),pad=3840:3840:(3840-iw)/2:(3840-ih)/2:color=black" "$output"

    # Remove the intermediate white border image
    rm "${filename%.*}-white_border.jpg"
  }

  # Check if at least one argument is provided
  if [ $# -eq 0 ]; then
    echo "Please provide at least one image file as an argument."
    return 1
  fi

  # Process each image file
  for image in "$@"; do
    if [ -f "$image" ]; then
      process_image "$image"
    else
      echo "File not found: $image"
    fi
  done
}

# `safe` wraps a command inside Agent Safehouse. Grants read-only access to Claude config and
# dotfiles, read-write access to the current directory, and passes through environment variables
# needed by cmux and GitHub tooling.
safe() {
  # Print if diffity CLI is out of date
  DIFFITY_LOCAL="$(diffity --version)"
  DIFFITY_LATEST="$(npm view diffity version)"
  if [[ -n "$DIFFITY_LOCAL" && -n "$DIFFITY_LATEST" && "$DIFFITY_LOCAL" != "$DIFFITY_LATEST" ]]
  then
    echo "╭───────────────────────────────────────────╮"
    echo "│  diffity $DIFFITY_LOCAL → $DIFFITY_LATEST update available   │"
    echo "│  run: npm install -g diffity              │"
    echo "╰───────────────────────────────────────────╯"
    echo ""
  fi

  GH_REPO_SLUG="$(gh-repo-slug 2>/dev/null || echo "")" \
    safehouse \
      --add-dirs-ro="$HOME/.claude" \
      --add-dirs-ro="$HOME/projects/github.com/revett/dotfiles" \
      --add-dirs="$HOME/Library/Application Support/cmux" \
      --add-dirs="$HOME/Library/Caches/io.sentry" \
      --add-dirs="$HOME/.diffity" \
      --add-dirs="$(pwd)" \
      --env-pass="CMUX_WORKSPACE_ID,GH_REPO_SLUG" \
      --append-profile="$SAFEHOUSE_APPEND_PROFILE" \
      "$@"
}

# `tre` is a shorthand for `tree` with hidden files and color enabled, ignoring the `.git`
# directory, listing directories first. The output gets piped into `less` with options to preserve
# color and line numbers, unless the output is small enough for one screen.
tre() {
  if ! command -v tree &> /dev/null; then
      echo "error: tree command could not be found."
      return 1
  fi

  tree -aC -I '.git|node_modules|.cache' --dirsfirst "$@" | less -FRNX;
}
