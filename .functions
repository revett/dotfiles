#!/usr/bin/env bash
#
# Functions
#
# @author Charlie Revett

# `asd` outputs all available functions from this file.
asd() {
  echo "> Available bash functions"
  echo "> See: ~/projects/github.com/revett/dotfiles/.functions"
  grep '^[a-z].*()' ~/projects/github.com/revett/dotfiles/.functions | grep -v '^asd' | sed 's/() {//' | sed 's/^/  - /'
}

# `branch` is used within a number of aliases, and returns the branch from the current git
# directory. Taken from oh-my-zsh.
# See: https://gist.github.com/DavidToca/3086571
branch() {
  ref=$(git symbolic-ref HEAD 2> /dev/null) || return
  echo ${ref#refs/heads/}
}

# `cc` starts a Claude Code session inside Agent Safehouse with full tool access.
cc() {
  clear
  cmux set-status claude 'Ready' --icon sparkle --color '#51a2ff' > /dev/null
  safe claude --effort xhigh --model opus --dangerously-skip-permissions "$@"
}

# `ccf` starts a Claude Code session inside Agent Safehouse with full tool access, using the fable
# model.
ccf() {
  clear
  cmux set-status claude 'Ready' --icon sparkle --color '#51a2ff' > /dev/null
  safe claude --effort xhigh --model fable --dangerously-skip-permissions "$@"
}

# `ccl` starts a lighweight Claude Code session inside Agent Safehouse, using a cheaper model and
# effort level to reduce cost.
ccl() {
  clear
  cmux set-status claude 'Ready' --icon sparkle --color '#51a2ff' > /dev/null
  safe claude --effort high --model sonnet --dangerously-skip-permissions "$@"
}

# `cmuxhelp` is a function to show the available cmux aliases.
cmuxhelp() {
  echo "> Available cmux aliases"
  echo "> See: ~/projects/github.com/revett/dotfiles/.aliases, ~/projects/github.com/revett/dotfiles/.functions"
  alias | grep "='cmux " | sed "s/^/  - /"
}

# `githelp` is a function to show the available Git aliases and functions.
githelp() {
  echo "> Available Git aliases"
  echo "> See: ~/projects/github.com/revett/dotfiles/.aliases, ~/projects/github.com/revett/dotfiles/.functions"
  alias | grep "='git " | sed "s/^/  - /"
  echo "  - gpush → Force push current branch (blocks main)"
  echo "  - gpush --yolo → Regular push on main (side projects)"
  echo "> Flows:"
  echo "  - gfo → grebase → gpush"
}

# `gh-repo-slug` returns the GitHub owner/repo slug (e.g. "revett/dotfiles") for the current git
# repository, derived from the origin remote URL. Supports both SSH and HTTPS remotes.
gh-repo-slug() {
  local url
  url=$(git remote get-url origin 2>/dev/null) || {
    echo "error: not a git repository or no origin remote" >&2
    return 1
  }

  local slug
  case "$url" in
    git@github.com:*)
      slug="${url#git@github.com:}"
      ;;
    https://github.com/*)
      slug="${url#https://github.com/}"
      ;;
    *)
      echo "error: origin is not a github.com remote" >&2
      return 1
      ;;
  esac

  slug="${slug%.git}"
  echo "$slug"
}

# `gpush` is a function to push the current branch to the remote repository. It will force push
# the branch if the current branch is not main. It will also allow for a `--yolo` flag to bypass
# the main branch check.
gpush() {
  if [ "$(branch)" = "main" ]; then
    if [ "$1" = "--yolo" ]; then
      git push
      return
    fi
    echo "error: don't force push main (use gpush --yolo)"
    return 1
  fi
  git push --force-with-lease --set-upstream origin "$(branch)"
}

# `safe` wraps a command inside Agent Safehouse, granting specific access to parts of the machine.
safe() {
  # On work machine, grant read-only access to the team-plain monorepo
  local -a work_mounts=()
  if [[ "$DOTFILES_MACHINE_TYPE" == "WORK" ]]; then
    work_mounts+=(--add-dirs-ro="$HOME/projects/github.com/team-plain")
  fi

  GH_REPO_SLUG="$(gh-repo-slug 2>/dev/null || echo "")" \
    safehouse \
      --enable=shell-init,cloud-credentials,1password \
      --add-dirs-ro="$HOME/.claude" \
      --add-dirs-ro="$HOME/projects/github.com/revett/dotfiles" \
      "${work_mounts[@]}" \
      --add-dirs="$HOME/projects/scratchpad" \
      --add-dirs="$HOME/.local/state/cmux" \
      --add-dirs="$HOME/Library/Caches/io.sentry" \
      --add-dirs="$(pwd)" \
      --env-pass="CMUX_WORKSPACE_ID,CMUX_SURFACE_ID,CMUX_SOCKET_PATH,GH_REPO_SLUG" \
      --append-profile="$SAFEHOUSE_APPEND_PROFILE" \
      "$@"
}

# `tre` is a shorthand for `tree` with hidden files and color enabled, ignoring the `.git`
# directory, listing directories first. The output gets piped into `less` with options to preserve
# color and line numbers, unless the output is small enough for one screen.
tre() {
  if ! command -v tree &> /dev/null; then
    echo "error: tree command could not be found."
    return 1
  fi

  tree -aC -I '.git|node_modules|.cache' --dirsfirst "$@" | less -FRNX;
}
