;; Local overrides for Agent Safehouse
;; Symlinked from ~/projects/github.com/revett/dotfiles

;; Allow osascript to send macOS notifications (used by Claude hooks)
(allow mach-lookup
  (global-name "com.apple.hiservices-xpcservice")
  (global-name "com.apple.usernoted.daemon_client")
  (global-name "com.apple.UNCUserNotification"))

;; Allow writing to ~/Downloads (used by invoice generation)
(allow file-write*
  (home-subpath "/Downloads"))
